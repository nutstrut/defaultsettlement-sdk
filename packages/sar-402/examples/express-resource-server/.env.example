# Copy to .env (or just export these) to configure the demo.

# DefaultVerifier base URL.
#   Normal mode (default): https://defaultverifier.com
#   Fail-open mode:        http://127.0.0.1:9   (intentionally unreachable)
DEFAULTVERIFIER_URL=https://defaultverifier.com

# Optional API key, sent as `Authorization: Bearer <key>`.
# DEFAULTSETTLEMENT_API_KEY=

# Port for the demo server (default 3000).
# PORT=3000

# Per-receipt HTTP timeout in ms (default 4000).
# SAR402_TIMEOUT_MS=4000

# Reported issuer environment: production | staging | test | local
# SAR402_ENVIRONMENT=production
