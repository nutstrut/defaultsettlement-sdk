{
  "name": "@defaultsettlement/canonical",
  "version": "0.1.0",
  "private": true,
  "description": "Neutral shared primitives for Default Settlement: deterministic canonical JSON, sha256 digests, digest/identity/action-type validators, content/body digesting, and Ed25519 signed-record envelope helpers. Does not provide key discovery or a public key registry.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "default-settlement",
    "canonical",
    "jcs",
    "rfc8785",
    "sha256",
    "ed25519",
    "signed-record"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
